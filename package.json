{
  "name": "octara-search",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "workspaces": [
    "api",
    "crawler",
    "frontend",
    "indexer"
  ],
  "scripts": {
    "start:api": "npm start --prefix api",
    "dev:api": "npm run dev --prefix api",
    "start:crawler": "npm start --prefix crawler",
    "prod:crawler": "IDLE_START=true QUIET=true npm run start:crawler",
    "crawler:monitor": "ts-node crawler/src/monitor.ts",
    "crawler:remote": "nohup npm run start:crawler > crawler.log 2>&1 &",
    "start:indexer": "npm start --prefix indexer",
    "start:maintenance": "ts-node crawler/src/maintenance.ts",
    "crawler:refresh": "ts-node crawler/src/refresh.ts",
    "dev:frontend": "npm run dev --prefix frontend",
    "prod:frontend": "npm run build --prefix frontend && npm run start --prefix frontend",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
    "prod": "npm run build --prefix frontend && PORT=$(grep '^PORT=' .env | cut -d '=' -f 2 || echo 4032) concurrently \"npm run start --prefix frontend\" \"npm run start:api\" \"npm run prod:crawler\""
  },
  "dependencies": {
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "bloom-filters": "^3.0.4",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "minisearch": "^7.2.0",
    "next": "16.2.2",
    "node-cron": "^4.2.1",
    "p-limit": "^7.3.0",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": "^5.11.0",
    "request-ip": "^3.3.0",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^4.2.2",
    "undici": "^8.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/request-ip": "^0.0.41",
    "@types/xml2js": "^0.4.14",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.2",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
